---
import '../styles/global.css';
const { title = 'Latent — A Masterclass', desc = 'Understand neural networks, latent space, and continuous machines from first shapes.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='8' fill='%237c9cff'/%3E%3C/svg%3E" />
  </head>
  <body>
    <nav class="site-nav">
      <div class="wrap">
        <a class="brand" href="/"><span class="dot"></span> latent.masterclass</a>
        <a class="nav-link" href="/#curriculum">curriculum →</a>
      </div>
    </nav>
    <slot />
    <footer class="site">
      <div class="wrap">a masterclass on models at rest &amp; machines in motion</div>
    </footer>
  </body>
</html>
